{
  "name": "oomni",
  "version": "1.0.0",
  "description": "OOMNI — 딸깍 하나로 AI 팀이 일한다",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n BACKEND,VITE,ELECTRON -c green,cyan,yellow \"npm run dev:backend\" \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:vite": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:5174 http://localhost:3001/api/health && cross-env ELECTRON_IS_DEV=true electron .",
    "build": "cd frontend && npm run build && cd ../backend && npm run build",
    "package": "npm run build && electron-builder",
    "test": "cd backend && npm test"
  },
  "build": {
    "appId": "com.oomni.app",
    "productName": "OOMNI",
    "directories": { "output": "dist-app" },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/dist/**/*",
      "backend/package.json"
    ],
    "extraResources": [
      { "from": "backend", "to": "backend" }
    ],
    "win": { "target": "nsis", "icon": "assets/icon.ico" },
    "mac": { "target": "dmg", "icon": "assets/icon.icns" },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "wait-on": "^8.0.0"
  }
}
